<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tag Views -->
        <record id="view_handmade_knowledge_tag_tree" model="ir.ui.view">
            <field name="name">handmade.knowledge.tag.tree</field>
            <field name="model">handmade.knowledge.tag</field>
            <field name="arch" type="xml">
                <list string="Tags" editable="bottom">
                    <field name="name"/>
                    <field name="color" widget="color_picker"/>
                </list>
            </field>
        </record>

        <record id="action_handmade_knowledge_tag" model="ir.actions.act_window">
            <field name="name">Tags</field>
            <field name="res_model">handmade.knowledge.tag</field>
            <field name="view_mode">list</field>
        </record>

        <!-- Article Views -->
        <record id="view_handmade_knowledge_article_tree" model="ir.ui.view">
            <field name="name">handmade.knowledge.article.tree</field>
            <field name="model">handmade.knowledge.article</field>
            <field name="arch" type="xml">
                <list string="Articles">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="parent_id"/>
                    <field name="visibility"/>
                    <field name="source_type"/>
                    <field name="dimension"/>
                    <field name="functional_topic"/>
                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                    <field name="author_id"/>
                    <field name="create_date"/>
                    <field name="is_favorite" widget="boolean_favorite" nolabel="1"/>
                </list>
            </field>
        </record>

        <record id="view_handmade_knowledge_article_form" model="ir.ui.view">
            <field name="name">handmade.knowledge.article.form</field>
            <field name="model">handmade.knowledge.article</field>
            <field name="arch" type="xml">
                <form string="Article">
                    <sheet>
                        <div class="row">
                            <!-- Left Column: Content Area (Responsive Grid) -->
                            <div class="col-12 col-md-8 col-lg-9 mb-4 mb-md-0">
                                <!-- Breadcrumb Hierarchy -->
                                <div class="mb-2">
                                    <field name="breadcrumb_path" readonly="1" class="text-muted small" nolabel="1"/>
                                </div>
                                <!-- Title -->
                                <div class="oe_title">
                                    <label for="name" class="oe_edit_only" string="Article Title"/>
                                    <h1>
                                        <field name="name" placeholder="e.g. Welcome nhan.lt07424@sinhvien.ho..."/>
                                    </h1>
                                </div>
                                <!-- HTML Editor -->
                                <div class="mt-4">
                                    <field name="content" widget="html" class="oe_sandbox" options="{'style-inline': true}"/>
                                </div>
                                <!-- Sub-articles List -->
                                <div class="mt-5">
                                    <h4 class="mb-3 text-secondary"><i class="fa fa-sitemap me-1"/> Sub-articles</h4>
                                    <field name="child_ids" context="{'default_parent_id': id}">
                                        <list editable="bottom">
                                            <field name="sequence" widget="handle"/>
                                            <field name="name"/>
                                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                            <field name="author_id"/>
                                        </list>
                                    </field>
                                </div>
                            </div>

                            <!-- Right Column: Properties Panel (Responsive Grid Card Layout) -->
                            <div class="col-12 col-md-4 col-lg-3">
                                <div class="p-3 bg-light rounded shadow-sm border border-light" style="min-height: 500px;">
                                    <h4 class="mb-3 text-primary pb-2 border-bottom"><i class="fa fa-cog me-1"/> Properties</h4>
                                    
                                    <div class="mb-3 d-flex align-items-center justify-content-between">
                                        <span class="fw-bold"><i class="fa fa-star text-warning me-1"/> Favorite:</span>
                                        <field name="is_favorite" widget="boolean_favorite"/>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="visibility" class="fw-bold form-label d-block mb-1" string="Visibility"/>
                                        <field name="visibility" widget="radio"/>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="parent_id" class="fw-bold form-label d-block mb-1" string="Parent Article"/>
                                        <field name="parent_id" options="{'no_create_edit': True}"/>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="source_type" class="fw-bold form-label d-block mb-1" string="Source"/>
                                        <field name="source_type"/>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="dimension" class="fw-bold form-label d-block mb-1" string="Dimension"/>
                                        <field name="dimension"/>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="functional_topic" class="fw-bold form-label d-block mb-1" string="Functional Topic"/>
                                        <field name="functional_topic" placeholder="e.g. Methodological"/>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="property_4" class="fw-bold form-label d-block mb-1" string="Property 4"/>
                                        <field name="property_4" placeholder="Value..."/>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="tag_ids" class="fw-bold form-label d-block mb-1" string="Tags"/>
                                        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="sequence" class="fw-bold form-label d-block mb-1" string="Sequence"/>
                                        <field name="sequence"/>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="author_id" class="fw-bold form-label d-block mb-1" string="Author"/>
                                        <field name="author_id" readonly="1"/>
                                    </div>
                                    
                                    <div class="mb-3 pt-2 border-top">
                                        <label for="active" class="fw-bold form-label d-block mb-1" string="Active"/>
                                        <field name="active" widget="boolean_toggle"/>
                                        <span class="text-muted small d-block mt-1">Uncheck to archive and move to Trash bin.</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_handmade_knowledge_article_kanban" model="ir.ui.view">
            <field name="name">handmade.knowledge.article.kanban</field>
            <field name="model">handmade.knowledge.article</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" default_group_by="visibility">
                    <field name="id"/>
                    <field name="name"/>
                    <field name="parent_id"/>
                    <field name="tag_ids"/>
                    <field name="is_favorite"/>
                    <field name="author_id"/>
                    <field name="visibility"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <div class="d-flex justify-content-between mb-2">
                                    <strong class="o_kanban_record_title" style="font-size: 1.1em;">
                                        <field name="name"/>
                                    </strong>
                                    <field name="is_favorite" widget="boolean_favorite"/>
                                </div>
                                <div class="mb-2">
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <div class="text-muted small">
                                        <t t-if="record.parent_id.raw_value">
                                            <i class="fa fa-folder-o mr-1" title="Parent Folder"/> <field name="parent_id"/>
                                        </t>
                                    </div>
                                    <field name="author_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_handmade_knowledge_article_search" model="ir.ui.view">
            <field name="name">handmade.knowledge.article.search</field>
            <field name="model">handmade.knowledge.article</field>
            <field name="arch" type="xml">
                <search string="Search Articles">
                    <field name="name" string="Title"/>
                    <field name="content" string="Content"/>
                    <field name="tag_ids"/>
                    <filter string="Workspace" name="visibility_workspace" domain="[('visibility', '=', 'workspace')]"/>
                    <filter string="Shared" name="visibility_shared" domain="[('visibility', '=', 'shared')]"/>
                    <filter string="Private" name="visibility_private" domain="[('visibility', '=', 'private')]"/>
                    <separator/>
                    <filter string="Favorites" name="favorite" domain="[('is_favorite', '=', True)]"/>
                    <filter string="Root Articles" name="root" domain="[('parent_id', '=', False)]"/>
                    <separator/>
                    <filter string="Trash (Archived)" name="inactive" domain="[('active', '=', False)]"/>
                    <separator/>
                    <filter string="Group by Parent Article" name="group_by_parent" context="{'group_by': 'parent_id'}"/>
                    <filter string="Group by Visibility" name="group_by_visibility" context="{'group_by': 'visibility'}"/>
                    <filter string="Group by Author" name="group_by_author" context="{'group_by': 'author_id'}"/>
                </search>
            </field>
        </record>

        <!-- Actions -->
        <record id="action_handmade_knowledge_article" model="ir.actions.act_window">
            <field name="name">Articles</field>
            <field name="res_model">handmade.knowledge.article</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="search_view_id" ref="view_handmade_knowledge_article_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first knowledge article!
                </p>
                <p>
                    Organize your team's SOPs, guidelines, and documentation in a structured tree.
                </p>
            </field>
        </record>

        <!-- Menu Structure -->
        <menuitem id="menu_handmade_knowledge_root"
                  name="Handmade Knowledge"
                  sequence="15"/>

        <menuitem id="menu_handmade_knowledge_article"
                  name="Articles"
                  parent="menu_handmade_knowledge_root"
                  action="action_handmade_knowledge_article"
                  sequence="10"/>

        <menuitem id="menu_handmade_knowledge_configuration"
                  name="Configuration"
                  parent="menu_handmade_knowledge_root"
                  sequence="100"/>

        <menuitem id="menu_handmade_knowledge_tag"
                  name="Tags"
                  parent="menu_handmade_knowledge_configuration"
                  action="action_handmade_knowledge_tag"
                  sequence="10"/>
    </data>
</odoo>
